{
  "manifest_version": 3,
  "name": "TikTok Order Extractor",
  "version": "4.0",
  "description": "Tu dong lay SDT va dia chi khach hang tu TikTok Seller Center - 1 tai khoan, tung trang san pham",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://seller-vn.tiktok.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://seller-vn.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TikTok Order Extractor"
  }
}
